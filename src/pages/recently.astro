---
import Layout from '@/layouts/Layout.astro';
import { getToken } from '@/lib/auth';
import { loadRecentlyReadItems } from '@/lib/data';
import type { Item as ItemType } from '@/lib/types';
import Item from '@/components/Item.astro';

// 1. Get token and context
const token = getToken(Astro.cookies);
if (!token) {
    return Astro.redirect('/login');
}

// 2. Fetch data
const items: ItemType[] = await loadRecentlyReadItems(Astro, token);
---

<Layout title="Recently Read">
    <div class="py-4">
        <h1 class="text-2xl font-bold mb-4">Recently Read Items ({items.length})</h1>
        <div class="flex flex-col">
            {items.length > 0 ? (
                items.map(item => <Item item={item} />)
            ) : (
                <p class="text-center text-gray-500 mt-8">No recently read items found.</p>
            )}
        </div>
    </div>
</Layout>
